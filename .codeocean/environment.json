{
	"version": 1,
	"base_image": "codeocean/mambaforge3:23.1.0-4-python3.10.12-ubuntu22.04",
	"options": {
		"registry_host_arg": true,
		"git_ask_pass": true,
		"mount_secrets": true
	},
	"installers": {
		"apt": {
			"packages": [
				{
					"name": "build-essential",
					"version": "12.9ubuntu3"
				}
			],
			"install_software_properties_common": true
		},
		"pip3": {
			"packages": [
				{
					"name": "anthropic",
					"version": "0.86.0"
				},
				{
					"name": "eval-type-backport",
					"version": "0.3.1"
				},
				{
					"name": "lazynwb",
					"version": "0.2.83"
				},
				{
					"name": "pydantic-settings",
					"version": "2.11.0"
				}
			],
			"options": {},
			"pre_install_options": {}
		}
	}
}